rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    match /community_messages/{messageId} {
      allow read: if true;
      allow create: if isValidId(messageId) && 
                     incoming().text is string && incoming().text.size() > 0 &&
                     incoming().color is string &&
                     incoming().createdAt == request.time;
    }

    match /healing_stats/global {
      allow read: if true;
      allow create: if true;
      allow update: if true; // In a real app we'd harden this, but for now ensure it works
    }

    // Connectivity test path
    match /test/connection {
      allow read: if true;
    }
  }
}
